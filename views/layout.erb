<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projekt #2</title>
    <link rel="stylesheet" type="text/css" href="/style.css?<%=Time.now.to_i%>">
</head>
<body>
  <header>
        <h1 class="logo">Exercises</h1>
        
        <% if @current_user %>
          <form class="delete" action="/logout" method="post">
            <input type="submit" value="Logga ut">
          </form>
        <% else %>
          <form class="button-group" action="/login" method="get">
            <input type="submit" value="Logga in">
          </form>
        <% end %>

    </header>
    <hr>
  <nav>
    <ul>
      <li><a href="/exercises">All exercises</a></li>
      <li><a href="/exercises/programs">Programs</a></li>
      <li><a href="/exercises/new">Ny övning</a></li>
    </ul>

  </nav>
  <hr> <%= yield%>
</body>
</html>