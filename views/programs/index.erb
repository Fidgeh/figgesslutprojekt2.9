<h2> All programs </h2>

<% @programs.each do |prog| %>
    <a href="/programs/<%= prog["id"] %>">
        <h3 class="exercise-title"> <%= prog['name'] %> </h3>
    </a>

    <% if is_admin? %>
        <div class="button-group">
            <form class="delete" action="/program/<%= prog["id"]%>/delete" method="post">
                <input type="submit" value="ta bort">
            </form>
        </div>

        <div class="button-group">
            <form class="update" action="/program/<%= prog["id"]%>/edit" method="get">
                <input type="submit" value="ändra">
            </form>
        </div>

    <% end %>
<% end %>